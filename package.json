{
  "name": "earth-survival-diary",
  "private": true,
  "version": "2.4.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "build": "vite build",
    "electron:build:win": "npm run build && node scripts/install-deps.cjs && node scripts/make-ico.cjs && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --win && node scripts/fix-latest-yml.cjs && node scripts/cleanup-release.cjs"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "cors": "^2.8.5",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "electron-updater": "^6.8.3",
    "element-plus": "^2.13.6",
    "express": "^4.18.2",
    "lunar-javascript": "^1.7.7",
    "marked": "^17.0.5",
    "pinia": "^3.0.4",
    "vditor": "^3.11.2",
    "vue": "^3.5.24",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^7.0.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "typescript": "^5.8.5",
    "vite": "^8.0.8",
    "vue-tsc": "^3.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "sharp"
    ]
  },
  "build": {
    "appId": "com.earth-survival-diary.app",
    "productName": "地球 Online 生存日记",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/**/*",
      "package.json",
      "README.md",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "build/icon.png"
      },
      {
        "from": "electron/node_modules",
        "to": "node_modules"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "include": "scripts/installer.nsh"
    },
    "publish": {
      "provider": "generic",
      "url": "https://raw.githubusercontent.com/XueWerY/earth-survival-diary/master/release"
    }
  }
}
